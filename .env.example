# ── Google Drive OAuth ───────────────────────────────────────────────────────
# Setup (5 minuti, una volta sola):
# 1. Vai su https://console.cloud.google.com
# 2. Crea un nuovo progetto (es. "MOD PMO")
# 3. API & Services → Enable APIs → cerca "Google Drive API" → Abilita
# 4. API & Services → Credentials → Create Credentials → OAuth Client ID
#    - Application type: Web application
#    - Authorized redirect URIs: http://localhost:3000/api/drive/callback
# 5. Copia Client ID e Client Secret qui sotto

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/drive/callback
GOOGLE_DRIVE_FOLDER_ID=1DRn8CQPBbDV4IIt4VG0kuWPm0tfROkFW
